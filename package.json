{
  "name": "flock",
  "productName": "Flock",
  "version": "1.0.0",
  "description": "Flock — run a whole flock of terminals side by side in one window. Rename and describe each pen, resize or reorder them, switch between a compact scrolling layout and a fixed grid, and theme it your way.",
  "keywords": [
    "terminal",
    "electron",
    "macos",
    "pty",
    "xterm",
    "flock"
  ],
  "homepage": "https://github.com/bethandutton/flock",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "author": "Bethan Dutton",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "electron": "^33.2.1"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0"
  }
}
