{
  "name": "flock",
  "productName": "Flock",
  "version": "1.2.0",
  "description": "Flock: run a whole flock of terminals side by side in one window. Rename each pen, resize or reorder them, switch between a compact scrolling layout and a fixed grid, and theme it your way.",
  "keywords": [
    "terminal",
    "electron",
    "macos",
    "pty",
    "xterm",
    "flock"
  ],
  "homepage": "https://github.com/bethandutton/flock",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "APPLE_KEYCHAIN_PROFILE=flock-notary electron-builder --mac",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "build": {
    "appId": "com.bethandutton.flock",
    "productName": "Flock",
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "assets/icon.icns",
      "hardenedRuntime": true,
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "${productName}-${version}.${ext}"
    },
    "dmg": {
      "background": "assets/dmg-background.tiff",
      "window": {
        "width": 540,
        "height": 380
      },
      "iconSize": 96,
      "contents": [
        {
          "x": 130,
          "y": 242,
          "type": "file"
        },
        {
          "x": 410,
          "y": 242,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "themes.js",
      "index.html",
      "prefs.js",
      "prefs.html",
      "styles.css",
      "assets/icon.png",
      "assets/icon.icns",
      "assets/welcome.mp4"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "bethandutton",
        "repo": "flock"
      }
    ]
  },
  "author": "Bethan Dutton",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "electron": "^33.2.1",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "electron-updater": "^6.8.9",
    "node-pty": "^1.0.0"
  }
}
